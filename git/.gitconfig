[user]
	name = djjolicoeur
	email = djjolicoeur@gmail.com

[init]
	defaultBranch = main

[push]
	default = simple
	autoSetupRemote = true
	followTags = true

[pull]
	rebase = false
	ff = only

[fetch]
	prune = true

[rebase]
	autoSquash = true
	autoStash = true

[diff]
	algorithm = histogram
	colorMoved = default

[merge]
	conflictStyle = zdiff3

[color]
	ui = auto

[core]
	editor = vim
	autocrlf = input
	excludesfile = ~/.gitignore_global

[credential]
	helper = osxkeychain

[alias]
	st = status -sb
	co = checkout
	br = branch
	ci = commit
	lg = log --graph --pretty=format:'%C(auto)%h%d %s %C(green)(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
	last = log -1 HEAD
	unstage = reset HEAD --
	amend = commit --amend --no-edit

[url "git@github.com:"]
	insteadOf = https://github.com/
